<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Сертификаты и лицензии</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header.njk' %}
        <main class="main">

            <!--Хлебные крошки-->
            <div class="breadcrumbs">
                <div class="container">
                    <ul>
                        <li>
                            <a href="#">
                                <div class="home-icon">
                                    <svg aria-hidden="true" width="18" height="19">
                                        <use xlink:href="img/sprite.svg#home"></use>
                                    </svg>
                                </div>
                                <span>Главная</span>
                            </a>
                        </li>
                        <li>
                            <a href="#">
                                <span>О компании</span>
                            </a>
                        </li>
                        <li><span>Сертификаты и лицензии</span></li>
                    </ul>
                </div>
            </div>

            <!--Сертификаты и лицензии-->
            <div class="block-sertificates block3">
                <div class="container">
                    <div class="block-title">
                        <div class="block-title__col">
                            <h1 class="title1">
                                Сертификаты и лицензии
                            </h1>
                            <p>
                                Аккредитации, партнёрские соглашения и подтверждения компетенций
                            </p>
                        </div>
                    </div>
                    <div class="block-sertificates__body">
                        <div class="block-sertificates__column">
                            <div class="block-sertificates__item">
                                <div class="block-sertificates__icon">
                                    <svg aria-hidden="true" width="30" height="38">
                                        <use xlink:href="img/sprite.svg#reestr"></use>
                                    </svg>
                                </div>
                                <div class="block-sertificates__titles">
                                    <div class="block-sertificates__title">
                                        Аккредитация лаборатории
                                    </div>
                                    <div class="block-sertificates__data">
                                        Действительна до 28.02.2028
                                    </div>
                                </div>
                            </div>
                            <a href="./" data-popup="#sertificate1" class="block-sertificates__image">
                                <img src="img/sertificate1.webp" alt="">
                            </a>
                        </div>
                        <div class="block-sertificates__column">
                            <div class="block-sertificates__item">
                                <div class="block-sertificates__icon">
                                    <svg aria-hidden="true" width="30" height="38">
                                        <use xlink:href="img/sprite.svg#reestr"></use>
                                    </svg>
                                </div>
                                <div class="block-sertificates__titles">
                                    <div class="block-sertificates__title">
                                        Сертификат соответствия
                                    </div>
                                    <div class="block-sertificates__data">
                                        Действителен до 28.02.2028
                                    </div>
                                </div>
                            </div>
                            <a href="./" data-popup="#sertificate2" class="block-sertificates__image">
                                <img src="img/sertificate1.webp" alt="">
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </main>
        {% include 'blocks/footer.njk' %}
    </div>
    <!--Галерея Сертификаты и лицензии-->
    <div id="sertificate1" aria-hidden="true" class="popup popup-image">
        <div class="popup__wrapper">
            <div class="popup__content">
                <div data-close class="popup__close">
                    <svg aria-hidden="true" width="14" height="14">
                        <use xlink:href="img/sprite.svg#close"></use>
                    </svg>
                </div>
                <div class="popup-image__body">
                    <img src="img/sertificate1.webp" alt="">
                </div>
            </div>
        </div>
    </div>
    <div id="sertificate2" aria-hidden="true" class="popup popup-image">
        <div class="popup__wrapper">
            <div class="popup__content">
                <div data-close class="popup__close">
                    <svg aria-hidden="true" width="14" height="14">
                        <use xlink:href="img/sprite.svg#close"></use>
                    </svg>
                </div>
                <div class="popup-image__body">
                    <img src="img/sertificate1.webp" alt="">
                </div>
            </div>
        </div>
    </div>
    {% include 'blocks/popups.njk' %}
    {% include 'blocks/scripts.njk' %}
</body>

</html>